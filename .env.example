# === I.S.A.A.C. Environment Configuration ===

# ---------------------------------------------------------------------------
# LLM Provider — primary backend
# ---------------------------------------------------------------------------
# One of: ollama | llamacpp | openai_compat | openai | anthropic
ISAAC_LLM_PROVIDER=ollama
ISAAC_MODEL_NAME=qwen2.5-coder:7b
ISAAC_TEMPERATURE=0.2
# Custom base URL — only needed for non-default endpoints
ISAAC_BASE_URL=

# Cloud API keys (only used for openai/anthropic providers or as fallbacks)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Local backends — Ollama (recommended)
# ---------------------------------------------------------------------------
ISAAC_OLLAMA_BASE_URL=http://localhost:11434
ISAAC_OLLAMA_LIGHT_MODEL=qwen2.5-coder:7b
ISAAC_OLLAMA_HEAVY_MODEL=qwen2.5-coder:7b

# ---------------------------------------------------------------------------
# Local backends — llama.cpp HTTP server
# ---------------------------------------------------------------------------
ISAAC_LLAMACPP_BASE_URL=http://localhost:8080
ISAAC_LLAMACPP_MODEL=local-model

# ---------------------------------------------------------------------------
# Local backends — generic OpenAI-compatible (LM Studio / vLLM / LiteLLM)
# ---------------------------------------------------------------------------
ISAAC_OPENAI_COMPAT_BASE_URL=
ISAAC_OPENAI_COMPAT_API_KEY=
ISAAC_OPENAI_COMPAT_MODEL=

# Fallback chain — providers tried when the primary is unhealthy
ISAAC_LLM_FALLBACK_PROVIDER=
ISAAC_LOCAL_FIRST=true

# ---------------------------------------------------------------------------
# Tiered model overrides (optional — blank inherits defaults)
# ---------------------------------------------------------------------------
ISAAC_FAST_MODEL=
ISAAC_FAST_TEMPERATURE=-1.0
ISAAC_STRONG_MODEL=
ISAAC_STRONG_TEMPERATURE=-1.0

# ---------------------------------------------------------------------------
# Vision (multimodal) — local VLM via Ollama
# ---------------------------------------------------------------------------
ISAAC_VISION_ENABLED=true
ISAAC_VISION_MODEL=llava:7b
ISAAC_VISION_STRONG_MODEL=

# ---------------------------------------------------------------------------
# Voice — local STT (Whisper) + TTS (Piper / Coqui / pyttsx3)
# ---------------------------------------------------------------------------
ISAAC_VOICE_ENABLED=true
# auto | cpu | cuda
ISAAC_VOICE_DEVICE=auto
# Whisper model size: tiny | base | small | medium | large-v3
ISAAC_VOICE_STT_MODEL=base
# ISO 639-1 (e.g. en, pt) — blank means auto-detect
ISAAC_VOICE_STT_LANGUAGE=
ISAAC_VOICE_STT_COMPUTE_TYPE=int8
# Piper voice — path or filename in PIPER_VOICE_DIR / ~/.isaac/voices
ISAAC_VOICE_TTS_VOICE=en_US-lessac-medium
ISAAC_VOICE_TTS_RATE=175
ISAAC_VOICE_TTS_SAMPLE_RATE=22050

# ---------------------------------------------------------------------------
# Self-improvement engine
# ---------------------------------------------------------------------------
ISAAC_IMPROVEMENT_ENABLED=false
ISAAC_IMPROVEMENT_INTERVAL_MINUTES=240
ISAAC_IMPROVEMENT_PROMOTE_RUNS=10
ISAAC_IMPROVEMENT_PROMOTE_THRESHOLD=0.85
ISAAC_IMPROVEMENT_DEPRECATE_RUNS=8
ISAAC_IMPROVEMENT_DEPRECATE_THRESHOLD=0.30

# ---------------------------------------------------------------------------
# Sandbox (code execution)
# ---------------------------------------------------------------------------
ISAAC_SANDBOX_IMAGE=isaac-sandbox:latest
ISAAC_SANDBOX_TIMEOUT_SECONDS=30
ISAAC_SANDBOX_MEMORY_LIMIT=256m
ISAAC_SANDBOX_CPU_LIMIT=1.0
ISAAC_SANDBOX_NETWORK=none

# ---------------------------------------------------------------------------
# UI Sandbox (virtual desktop — ComputerUse)
# ---------------------------------------------------------------------------
ISAAC_UI_SANDBOX_IMAGE=isaac-ui-sandbox:latest
ISAAC_UI_SANDBOX_TIMEOUT_SECONDS=120
ISAAC_UI_SANDBOX_MEMORY_LIMIT=1g
ISAAC_UI_SANDBOX_CPU_LIMIT=1.5
ISAAC_UI_SANDBOX_VNC_ENABLED=false
ISAAC_UI_SANDBOX_VNC_PORT=5900

# ---------------------------------------------------------------------------
# Graph configuration
# ---------------------------------------------------------------------------
ISAAC_MAX_RETRIES=3
ISAAC_MAX_ITERATIONS=10
ISAAC_MAX_UI_CYCLES=20

# ---------------------------------------------------------------------------
# Skill Library
# ---------------------------------------------------------------------------
ISAAC_SKILLS_DIR=skills

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
ISAAC_GUARD_SUSPICION_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Telegram Gateway
# ---------------------------------------------------------------------------
ISAAC_TELEGRAM_BOT_TOKEN=
ISAAC_TELEGRAM_ALLOWED_USERS=

# ---------------------------------------------------------------------------
# Heartbeat Scheduler
# ---------------------------------------------------------------------------
ISAAC_HEARTBEAT_INTERVAL_MINUTES=15

# ---------------------------------------------------------------------------
# Isaac Home (persistent data)
# ---------------------------------------------------------------------------
# ISAAC_ISAAC_HOME=~/.isaac

# ---------------------------------------------------------------------------
# Connectors
# ---------------------------------------------------------------------------
ISAAC_GITHUB_TOKEN=

ISAAC_EMAIL_IMAP_HOST=imap.gmail.com
ISAAC_EMAIL_USER=
ISAAC_EMAIL_PASSWORD=
ISAAC_EMAIL_IMAP_PORT=993

ISAAC_EMAIL_SMTP_HOST=smtp.gmail.com
ISAAC_EMAIL_SMTP_PORT=587
ISAAC_EMAIL_SMTP_USER=
ISAAC_EMAIL_SMTP_PASSWORD=

ISAAC_CALDAV_URL=
ISAAC_CALDAV_USERNAME=
ISAAC_CALDAV_PASSWORD=

ISAAC_OBSIDIAN_VAULT_PATH=
